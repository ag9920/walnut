#!/usr/bin/env python3
"""
Feishu Calendar CLI Tool

Agent-friendly CLI for managing Feishu Calendars, Events, Meeting Rooms,
and querying free/busy status across users and groups.
All output is JSON to stdout. Logs go to stderr.
"""

import argparse
import json
import os
import sys
import subprocess
import time
from datetime import datetime, timezone, timedelta
from typing import Any, Dict, List, Optional

try:
    import requests
except ImportError:
    print("Installing 'requests'...", file=sys.stderr)
    subprocess.check_call([sys.executable, "-m", "pip", "install", "requests"])
    import requests


# ═══════════════════════════════════════════════════════════════════════════════
# Feishu API Client
# ═══════════════════════════════════════════════════════════════════════════════

class FeishuClient:
    BASE = "https://open.feishu.cn/open-apis"

    def __init__(self, app_id: str, app_secret: str):
        self.app_id = app_id
        self.app_secret = app_secret
        self._token: Optional[str] = None
        self._expires_at: float = 0

    def _ensure_token(self):
        if self._token and time.time() < self._expires_at - 300:
            return
        resp = requests.post(
            f"{self.BASE}/auth/v3/tenant_access_token/internal",
            json={"app_id": self.app_id, "app_secret": self.app_secret},
            timeout=10,
        )
        resp.raise_for_status()
        d = resp.json()
        if d.get("code") != 0:
            raise RuntimeError(f"Auth failed: {d.get('msg')}")
        self._token = d["tenant_access_token"]
        self._expires_at = time.time() + d.get("expire", 7200)

    def _headers(self):
        self._ensure_token()
        return {
            "Authorization": f"Bearer {self._token}",
            "Content-Type": "application/json; charset=utf-8",
        }

    def request(self, method: str, path: str, params=None, json_data=None):
        url = f"{self.BASE}{path}"
        r = requests.request(method, url, headers=self._headers(),
                             params=params, json=json_data, timeout=30)
        try:
            data = r.json()
        except ValueError:
            r.raise_for_status()
            return {}
        if data.get("code") != 0:
            log_id = r.headers.get("X-Log-Id", "")
            msg = f"API Error {data.get('code')}: {data.get('msg')}"
            if log_id:
                msg += f" (LogID: {log_id})"
            print(msg, file=sys.stderr)
        return data

    def paginate(self, method, path, params=None, json_data=None,
                 items_key="items", page_size=50):
        """Auto-paginate and yield all items."""
        params = dict(params or {})
        params["page_size"] = page_size
        while True:
            if method.upper() == "GET":
                data = self.request("GET", path, params=params)
            else:
                data = self.request(method, path, params=params,
                                    json_data=json_data)
            items = data.get("data", {}).get(items_key, [])
            for item in items:
                yield item
            if not data.get("data", {}).get("has_more"):
                break
            pt = data.get("data", {}).get("page_token")
            if not pt:
                break
            params["page_token"] = pt


# ═══════════════════════════════════════════════════════════════════════════════
# Calendar Service
# ═══════════════════════════════════════════════════════════════════════════════

class CalendarService:
    def __init__(self, client: FeishuClient):
        self.c = client

    # ── Calendar CRUD ────────────────────────────────────────────────────────

    def get_primary(self):
        return self.c.request("POST", "/calendar/v4/calendars/primary",
                              params={"user_id_type": "open_id"})

    def resolve_primary_id(self) -> str:
        r = self.get_primary()
        cals = r.get("data", {}).get("calendars", [])
        if cals:
            return cals[0]["calendar"]["calendar_id"]
        raise RuntimeError("Cannot resolve primary calendar")

    def list_calendars(self, page_size=50):
        return list(self.c.paginate(
            "GET", "/calendar/v4/calendars",
            items_key="calendar_list", page_size=page_size))

    def search_calendars(self, query: str):
        return list(self.c.paginate(
            "POST", "/calendar/v4/calendars/search",
            json_data={"query": query}, items_key="items"))

    # ── Free/Busy ────────────────────────────────────────────────────────────

    def freebusy(self, time_min: str, time_max: str,
                 user_id: str = None, room_id: str = None):
        """Query one user or one room's busy intervals."""
        body = {"time_min": time_min, "time_max": time_max}
        if user_id:
            body["user_id"] = user_id
        elif room_id:
            body["room_id"] = room_id
        return self.c.request(
            "POST", "/calendar/v4/freebusy/list",
            params={"user_id_type": "open_id"}, json_data=body)

    def batch_freebusy(self, time_min: str, time_max: str,
                       user_ids: List[str] = None,
                       room_ids: List[str] = None):
        """Query multiple users/rooms in parallel, merge results."""
        results = {}
        for uid in (user_ids or []):
            r = self.freebusy(time_min, time_max, user_id=uid)
            results[uid] = r.get("data", {}).get("freebusy_list", [])
        for rid in (room_ids or []):
            r = self.freebusy(time_min, time_max, room_id=rid)
            results[rid] = r.get("data", {}).get("freebusy_list", [])
        return results

    # ── Event CRUD ───────────────────────────────────────────────────────────

    def create_event(self, calendar_id: str, summary: str,
                     start_time: str, end_time: str,
                     description: str = "", visibility: str = "default",
                     free_busy_status: str = "busy",
                     need_notification: bool = True):
        body = {
            "summary": summary,
            "start_time": {"timestamp": start_time},
            "end_time": {"timestamp": end_time},
            "need_notification": need_notification,
            "visibility": visibility,
            "free_busy_status": free_busy_status,
        }
        if description:
            body["description"] = description
        return self.c.request(
            "POST", f"/calendar/v4/calendars/{calendar_id}/events",
            params={"user_id_type": "open_id"}, json_data=body)

    def get_event(self, calendar_id: str, event_id: str):
        return self.c.request(
            "GET", f"/calendar/v4/calendars/{calendar_id}/events/{event_id}",
            params={"user_id_type": "open_id", "need_attendee": "true",
                    "max_attendee_num": 100})

    def list_events(self, calendar_id: str, start_time: str = None,
                    end_time: str = None, page_size: int = 200):
        params = {"user_id_type": "open_id", "page_size": page_size}
        if start_time:
            params["start_time"] = start_time
        if end_time:
            params["end_time"] = end_time
        return self.c.request(
            "GET", f"/calendar/v4/calendars/{calendar_id}/events",
            params=params)

    def search_events(self, calendar_id: str, query: str,
                      start_time: str = None, end_time: str = None,
                      user_ids: List[str] = None,
                      room_ids: List[str] = None):
        body: Dict[str, Any] = {"query": query}
        filt: Dict[str, Any] = {}
        if start_time:
            filt["start_time"] = {"timestamp": start_time}
        if end_time:
            filt["end_time"] = {"timestamp": end_time}
        if user_ids:
            filt["user_ids"] = user_ids
        if room_ids:
            filt["room_ids"] = room_ids
        if filt:
            body["filter"] = filt
        return self.c.request(
            "POST", f"/calendar/v4/calendars/{calendar_id}/events/search",
            params={"user_id_type": "open_id"}, json_data=body)

    def update_event(self, calendar_id: str, event_id: str, **fields):
        body = {}
        for k in ("summary", "description", "visibility",
                   "free_busy_status", "attendee_ability"):
            if k in fields and fields[k] is not None:
                body[k] = fields[k]
        if "start_time" in fields and "end_time" in fields:
            body["start_time"] = {"timestamp": fields["start_time"]}
            body["end_time"] = {"timestamp": fields["end_time"]}
        if "need_notification" in fields:
            body["need_notification"] = fields["need_notification"]
        if "location" in fields:
            body["location"] = {"name": fields["location"]}
        return self.c.request(
            "PATCH",
            f"/calendar/v4/calendars/{calendar_id}/events/{event_id}",
            params={"user_id_type": "open_id"}, json_data=body)

    def delete_event(self, calendar_id: str, event_id: str,
                     need_notification: bool = True):
        return self.c.request(
            "DELETE",
            f"/calendar/v4/calendars/{calendar_id}/events/{event_id}",
            params={"need_notification": str(need_notification).lower()})

    # ── Attendees ────────────────────────────────────────────────────────────

    def add_attendees(self, calendar_id: str, event_id: str,
                      attendees: List[Dict], need_notification: bool = True):
        body = {
            "attendees": attendees,
            "need_notification": need_notification,
        }
        return self.c.request(
            "POST",
            f"/calendar/v4/calendars/{calendar_id}/events/{event_id}/attendees",
            params={"user_id_type": "open_id"}, json_data=body)

    def list_attendees(self, calendar_id: str, event_id: str):
        return list(self.c.paginate(
            "GET",
            f"/calendar/v4/calendars/{calendar_id}/events/{event_id}/attendees",
            params={"user_id_type": "open_id"}, page_size=100))

    # ── Chat (Group) Members ─────────────────────────────────────────────────

    def list_chat_members(self, chat_id: str):
        return list(self.c.paginate(
            "GET", f"/im/v1/chats/{chat_id}/members",
            params={"member_id_type": "open_id"}, page_size=100))

    def list_chats(self, page_size=100):
        return list(self.c.paginate(
            "GET", "/im/v1/chats", page_size=page_size))

    # ── Meeting Room Search ──────────────────────────────────────────────────

    def search_rooms(self, keyword: str = None, room_level_id: str = None,
                     page_size: int = 50):
        """Search meeting rooms via vc/v1 API (needs user_access_token
        in production; with tenant_access_token it may have limited results).
        Falls back to calendar search if vc API fails."""
        body: Dict[str, Any] = {"page_size": page_size}
        if keyword:
            body["keyword"] = keyword
        if room_level_id:
            body["room_level_id"] = room_level_id
        r = self.c.request("POST", "/vc/v1/rooms/search", json_data=body)
        if r.get("code") == 0:
            return r.get("data", {}).get("rooms", [])
        # Fallback: search via calendar API for resource calendars
        print("vc/v1 search failed, falling back to calendar search",
              file=sys.stderr)
        if keyword:
            return self.search_calendars(keyword)
        return []

    def list_room_buildings(self, page_size=100):
        """List meeting room building levels."""
        return self.c.request(
            "GET", "/vc/v1/room_levels",
            params={"page_size": page_size})


# ═══════════════════════════════════════════════════════════════════════════════
# Helpers
# ═══════════════════════════════════════════════════════════════════════════════

def out(data):
    print(json.dumps(data, indent=2, ensure_ascii=False))


def resolve_cal_id(svc: CalendarService, raw: str) -> str:
    if raw == "primary":
        return svc.resolve_primary_id()
    return raw


# ═══════════════════════════════════════════════════════════════════════════════
# CLI Definition
# ═══════════════════════════════════════════════════════════════════════════════

def build_parser():
    p = argparse.ArgumentParser(description="Feishu Calendar CLI")
    p.add_argument("--app-id", help="Feishu App ID (env: FEISHU_APP_ID)")
    p.add_argument("--app-secret", help="Feishu App Secret (env: FEISHU_APP_SECRET)")
    sub = p.add_subparsers(dest="command", required=True)

    # ── primary ──────────────────────────────────────────────────────────────
    sub.add_parser("primary", help="Get bot's primary calendar")

    # ── list-calendars ───────────────────────────────────────────────────────
    sub.add_parser("list-calendars", help="List subscribed calendars")

    # ── search-calendars ─────────────────────────────────────────────────────
    sc = sub.add_parser("search-calendars", help="Search calendars/rooms")
    sc.add_argument("--query", required=True)

    # ── freebusy ─────────────────────────────────────────────────────────────
    fb = sub.add_parser("freebusy", help="Query free/busy for users/rooms")
    fb.add_argument("--time-min", required=True,
                    help="ISO8601 e.g. 2025-03-18T09:00:00+08:00")
    fb.add_argument("--time-max", required=True,
                    help="ISO8601 e.g. 2025-03-18T18:00:00+08:00")
    fb.add_argument("--user-ids",
                    help="Comma-separated open_ids")
    fb.add_argument("--room-ids",
                    help="Comma-separated room_ids (omm_xxx)")

    # ── create ───────────────────────────────────────────────────────────────
    cr = sub.add_parser("create", help="Create event + optional attendees/room")
    cr.add_argument("--calendar-id", required=True,
                    help="Calendar ID or 'primary'")
    cr.add_argument("--summary", required=True)
    cr.add_argument("--description", default="")
    cr.add_argument("--start-time", required=True,
                    help="Unix timestamp (seconds)")
    cr.add_argument("--end-time", required=True,
                    help="Unix timestamp (seconds)")
    cr.add_argument("--users",
                    help="Comma-separated open_ids to invite")
    cr.add_argument("--chat-id",
                    help="Invite entire chat group as attendee")
    cr.add_argument("--room-id", help="Room ID (omm_xxx) to book")
    cr.add_argument("--operate-id",
                    help="Human contact open_id (required for room booking)")
    cr.add_argument("--visibility", default="default",
                    choices=["default", "public", "private"])

    # ── get ───────────────────────────────────────────────────────────────────
    ge = sub.add_parser("get", help="Get event details")
    ge.add_argument("--calendar-id", required=True)
    ge.add_argument("--event-id", required=True)

    # ── list ──────────────────────────────────────────────────────────────────
    ls = sub.add_parser("list", help="List events in time range")
    ls.add_argument("--calendar-id", required=True,
                    help="Calendar ID or 'primary'")
    ls.add_argument("--start-time", help="Unix timestamp (seconds)")
    ls.add_argument("--end-time", help="Unix timestamp (seconds)")

    # ── search ────────────────────────────────────────────────────────────────
    se = sub.add_parser("search", help="Search events by keyword")
    se.add_argument("--calendar-id", required=True)
    se.add_argument("--query", required=True)
    se.add_argument("--start-time", help="Unix timestamp")
    se.add_argument("--end-time", help="Unix timestamp")

    # ── update ────────────────────────────────────────────────────────────────
    up = sub.add_parser("update", help="Update (patch) an event")
    up.add_argument("--calendar-id", required=True)
    up.add_argument("--event-id", required=True)
    up.add_argument("--summary")
    up.add_argument("--description")
    up.add_argument("--start-time", help="Unix timestamp")
    up.add_argument("--end-time", help="Unix timestamp")
    up.add_argument("--location")
    up.add_argument("--visibility",
                    choices=["default", "public", "private"])

    # ── delete ────────────────────────────────────────────────────────────────
    de = sub.add_parser("delete", help="Delete an event")
    de.add_argument("--calendar-id", required=True)
    de.add_argument("--event-id", required=True)
    de.add_argument("--silent", action="store_true",
                    help="Suppress attendee notification")

    # ── add-attendees ─────────────────────────────────────────────────────────
    aa = sub.add_parser("add-attendees", help="Add attendees to event")
    aa.add_argument("--calendar-id", required=True)
    aa.add_argument("--event-id", required=True)
    aa.add_argument("--users", help="Comma-separated open_ids")
    aa.add_argument("--chat-id", help="Group chat ID")
    aa.add_argument("--room-id", help="Room ID")
    aa.add_argument("--operate-id",
                    help="Human contact for room booking")

    # ── list-attendees ────────────────────────────────────────────────────────
    la = sub.add_parser("list-attendees", help="List event attendees")
    la.add_argument("--calendar-id", required=True)
    la.add_argument("--event-id", required=True)

    # ── chat-members ──────────────────────────────────────────────────────────
    cm = sub.add_parser("chat-members",
                        help="List members of a chat group")
    cm.add_argument("--chat-id", required=True)

    # ── list-chats ────────────────────────────────────────────────────────────
    sub.add_parser("list-chats", help="List chats the bot is in")

    # ── search-rooms ──────────────────────────────────────────────────────────
    sr = sub.add_parser("search-rooms", help="Search meeting rooms")
    sr.add_argument("--keyword", help="Room name keyword")
    sr.add_argument("--building", help="Building/level ID")

    # ── list-buildings ────────────────────────────────────────────────────────
    sub.add_parser("list-buildings",
                   help="List meeting room buildings/levels")

    return p


# ═══════════════════════════════════════════════════════════════════════════════
# Command Dispatch
# ═══════════════════════════════════════════════════════════════════════════════

def main():
    parser = build_parser()
    args = parser.parse_args()

    app_id = args.app_id or os.environ.get("FEISHU_APP_ID")
    app_secret = args.app_secret or os.environ.get("FEISHU_APP_SECRET")
    if not app_id or not app_secret:
        out({"code": -1, "msg": "Missing FEISHU_APP_ID / FEISHU_APP_SECRET"})
        sys.exit(1)

    client = FeishuClient(app_id, app_secret)
    svc = CalendarService(client)
    cmd = args.command

    try:
        if cmd == "primary":
            out(svc.get_primary())

        elif cmd == "list-calendars":
            out(svc.list_calendars())

        elif cmd == "search-calendars":
            out(svc.search_calendars(args.query))

        elif cmd == "freebusy":
            uids = [u.strip() for u in args.user_ids.split(",") if u.strip()] if args.user_ids else []
            rids = [r.strip() for r in args.room_ids.split(",") if r.strip()] if args.room_ids else []
            if len(uids) + len(rids) == 1:
                # Single query — return raw API response
                out(svc.freebusy(args.time_min, args.time_max,
                                 user_id=uids[0] if uids else None,
                                 room_id=rids[0] if rids else None))
            else:
                out(svc.batch_freebusy(args.time_min, args.time_max,
                                       user_ids=uids or None,
                                       room_ids=rids or None))

        elif cmd == "create":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            r = svc.create_event(
                cal_id, args.summary, args.start_time, args.end_time,
                description=args.description, visibility=args.visibility)
            if r.get("code") != 0:
                out(r)
                return
            event = r.get("data", {}).get("event", {})
            event_id = event.get("event_id")
            # Build attendee list
            attendees = []
            if args.users:
                for uid in args.users.split(","):
                    uid = uid.strip()
                    if uid:
                        attendees.append({"type": "user", "user_id": uid})
            if args.chat_id:
                attendees.append({"type": "chat", "chat_id": args.chat_id})
            if args.room_id:
                room_att = {"type": "resource", "room_id": args.room_id}
                if args.operate_id:
                    room_att["operate_id"] = args.operate_id
                attendees.append(room_att)
            if attendees and event_id:
                att_r = svc.add_attendees(cal_id, event_id, attendees)
                r["attendee_result"] = att_r
            out(r)

        elif cmd == "get":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            out(svc.get_event(cal_id, args.event_id))

        elif cmd == "list":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            out(svc.list_events(cal_id, args.start_time, args.end_time))

        elif cmd == "search":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            out(svc.search_events(cal_id, args.query,
                                  start_time=args.start_time,
                                  end_time=args.end_time))

        elif cmd == "update":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            fields = {}
            if args.summary: fields["summary"] = args.summary
            if args.description: fields["description"] = args.description
            if args.start_time and args.end_time:
                fields["start_time"] = args.start_time
                fields["end_time"] = args.end_time
            if args.location: fields["location"] = args.location
            if args.visibility: fields["visibility"] = args.visibility
            out(svc.update_event(cal_id, args.event_id, **fields))

        elif cmd == "delete":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            out(svc.delete_event(cal_id, args.event_id,
                                 need_notification=not args.silent))

        elif cmd == "add-attendees":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            attendees = []
            if args.users:
                for uid in args.users.split(","):
                    uid = uid.strip()
                    if uid:
                        attendees.append({"type": "user", "user_id": uid})
            if args.chat_id:
                attendees.append({"type": "chat", "chat_id": args.chat_id})
            if args.room_id:
                room_att = {"type": "resource", "room_id": args.room_id}
                if args.operate_id:
                    room_att["operate_id"] = args.operate_id
                attendees.append(room_att)
            out(svc.add_attendees(cal_id, args.event_id, attendees))

        elif cmd == "list-attendees":
            cal_id = resolve_cal_id(svc, args.calendar_id)
            out(svc.list_attendees(cal_id, args.event_id))

        elif cmd == "chat-members":
            out(svc.list_chat_members(args.chat_id))

        elif cmd == "list-chats":
            out(svc.list_chats())

        elif cmd == "search-rooms":
            out(svc.search_rooms(keyword=args.keyword,
                                 room_level_id=args.building))

        elif cmd == "list-buildings":
            out(svc.list_room_buildings())

    except Exception as e:
        out({"code": -1, "msg": str(e)})
        sys.exit(1)


if __name__ == "__main__":
    main()
